<?xml version="1.0" encoding="utf-8"?>
<!-- Dashboard widget (4×2) — full-bleed image with stats + record overlay -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_dashboard_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background">

    <!-- Full-bleed background image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_quick_record_bg"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <!-- Semi-transparent scrim for text legibility -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_scrim"
        android:contentDescription="@null"
        android:scaleType="fitXY" />

    <!-- Content overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header row: app title + Record button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Vaanix"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#EEFFFFFF"
                android:shadowColor="#88000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3" />

            <!-- REC button — larger touch target -->
            <TextView
                android:id="@+id/widget_record_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" REC "
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:background="@drawable/widget_btn_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- Stats row: Notes cell | Tasks cell — each tappable (hidden in minimal mode) -->
        <LinearLayout
            android:id="@+id/widget_stats_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <!-- Notes cell — tappable -->
            <LinearLayout
                android:id="@+id/widget_notes_cell"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_cell_bg"
                android:layout_marginEnd="4dp"
                android:padding="6dp">

                <TextView
                    android:id="@+id/widget_note_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notes"
                    android:textSize="11sp"
                    android:textColor="#CCFFFFFF"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

            </LinearLayout>

            <!-- Tasks cell — tappable -->
            <LinearLayout
                android:id="@+id/widget_tasks_cell"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/widget_cell_bg"
                android:layout_marginStart="4dp"
                android:padding="6dp">

                <TextView
                    android:id="@+id/widget_task_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open Tasks"
                    android:textSize="11sp"
                    android:textColor="#CCFFFFFF"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="3" />

            </LinearLayout>

        </LinearLayout>

        <!-- Minimal mode: centered REC button (hidden by default, shown in minimal mode) -->
        <FrameLayout
            android:id="@+id/widget_minimal_rec"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_minimal_rec_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=" REC "
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:background="@drawable/widget_btn_background"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

        </FrameLayout>

        <!-- Latest note preview (hidden when privacy mode restricts it) -->
        <TextView
            android:id="@+id/widget_latest_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textSize="10sp"
            android:textColor="#99FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"
            android:shadowColor="#88000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

</FrameLayout>
